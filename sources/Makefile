####### Compile

graphics.o: graphics.cpp graphics.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o graphics.o graphics.cpp

main.o: main.cpp main.h \
		graphics.h \
		shader_program.h \
		rectangle.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o main.cpp

rectangle.o: rectangle.cpp rectangle.h \
		shader_program.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o rectangle.o rectangle.cpp

shader_program.o: shader_program.cpp shader_program.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o shader_program.o shader_program.cpp

